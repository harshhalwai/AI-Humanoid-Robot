# Django Settings
SECRET_KEY=django-insecure-prod-ready-secret-key-replace-me-1234
DEBUG=True
ALLOWED_HOSTS=*,localhost,127.0.0.1

# Database Configuration
# Leave blank to use SQLite during development. Use Postgres URL for production.
# DATABASE_URL=postgresql://db_user:db_password@localhost:5432/robot_db

# Security & API Auth
# This key is used by the ESP32 to authorize HTTP requests to the Django Server
ROBOT_API_KEY=robot-secret-api-key-987654321

# Google Gemini API
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# Speech-to-Text (STT) Settings
# Options: 'whisper' (local faster-whisper) or 'google' (Google Speech API via HTTP)
STT_PROVIDER=google
WHISPER_MODEL_SIZE=tiny
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# Text-to-Speech (TTS) Settings
# Options: 'edge' (Microsoft Edge TTS - very natural & free) or 'google' (gTTS)
TTS_PROVIDER=edge
# Voices: 'en-US-GuyNeural', 'en-US-JennyNeural', 'hi-IN-MadhurNeural' (Hindi), etc.
EDGE_TTS_VOICE=en-US-GuyNeural

# Audio File Settings
# Delete generated response audio files after X minutes to save disk space
AUDIO_CLEANUP_AGE_MINUTES=10
